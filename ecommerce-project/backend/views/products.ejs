<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Products | Ali's Store</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="main-header">
        <div class="container header-top">
            <div class="logo-area">
                <a href="/"><img src="/assets/logo-colored.png" alt="Brand" class="logo-img" /></a>
            </div>

            <form action="/search" method="GET" class="search-bar">
                <input type="text" name="q" placeholder="Search products..." required />
                <button type="submit" class="btn-primary">Search</button>
            </form>

            <nav class="user-actions">
                <a href="/">Home</a>
                <a href="/products">Products</a>
            </nav>
        </div>
    </header>

    <main class="container">
        <h2 class="section-title">Explore Our Collection</h2>
        
        <div class="product-grid">
            <% if (products.length > 0) { %>
                <% products.forEach(product => { %>
                    <div class="product-card">
                        <img src="<%= product.image %>" alt="<%= product.name %>">
                        <div class="product-info">
                            <h3><%= product.name %></h3>
                            <p class="category"><%= product.category %></p>
                            <p class="price">$<%= product.price %></p>
                            <a href="/product/<%= product._id %>" class="btn-view">View Details</a>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="no-results">
                    <p>No products found. Try a different search term.</p>
                    <a href="/products">View All Products</a>
                </div>
            <% } %>
            </div>
    </main>

    <footer class="footer-section">
        <div class="container">
            <p>© 2026 Ecommerce Project - University of Karachi</p>
        </div>
    </footer>
</body>
</html>