<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> | Ali's Store</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* Internal styles to ensure the new features look good immediately */
        .details-wrapper {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            margin-top: 50px;
            align-items: start;
        }
        .image-section img {
            width: 100%;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        .category-tag {
            background: #f0f0f0;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            text-transform: uppercase;
            color: #666;
        }
        .seller-card {
            background: #f9f9f9;
            padding: 15px;
            border-radius: 10px;
            margin: 20px 0;
            border-left: 4px solid #007bff;
        }
        .price-tag {
            font-size: 2.5rem;
            font-weight: bold;
            color: #222;
            margin: 15px 0;
        }
        .buy-btn {
            width: 100%;
            padding: 15px;
            font-size: 1.1rem;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.3s;
        }
        .buy-btn:not(:disabled) { background: #007bff; color: white; }
        .buy-btn:disabled { background: #ccc; cursor: not-allowed; }
        .buy-btn:hover:not(:disabled) { background: #0056b3; }
        
        @media (max-width: 768px) {
            .details-wrapper { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <header class="main-header">
        <div class="container nav-flex">
            <div class="logo-area">
                <a href="/"><img src="/assets/logo-colored.png" alt="Ali's Shop" style="height: 40px;"></a>
            </div>
            <nav class="user-actions">
                <a href="/">Home</a>
                <a href="/products">Products</a>
            </nav>
        </div>
    </header>

    <main class="container details-wrapper">
        <div class="image-section">
            <img src="<%= product.image %>" alt="<%= product.name %>">
        </div>

        <div class="info-section">
            <span class="category-tag"><%= product.category %></span>
            <h1 style="margin-top: 10px;"><%= product.name %></h1>
            
            <div class="seller-card">
                <p style="margin: 0; color: #555; font-size: 0.9rem;">Sold by</p>
                <h4 style="margin: 5px 0;"><%= product.seller ? product.seller.name : 'Verified Ali Store Merchant' %></h4>
                <p style="margin: 0; font-size: 0.85rem; color: #007bff;"><%= product.seller ? product.seller.email : 'contact@alishop.com' %></p>
            </div>

            <p class="desc" style="line-height: 1.6; color: #444;"><%= product.description %></p>
            
            <div class="stock-status">
                <% if (product.stock > 0) { %>
                    <p class="in-stock" style="color: #28a745; font-weight: 600;">
                        ✅ In Stock: <%= product.stock %> units available
                    </p>
                <% } else { %>
                    <p class="out-of-stock" style="color: #dc3545; font-weight: 600;">
                        ❌ Currently Out of Stock
                    </p>
                <% } %>
            </div>

            <p class="price-tag">$<%= product.price %></p>
            
            <button class="buy-btn" <%= product.stock <= 0 ? 'disabled' : '' %>>
                <%= product.stock > 0 ? 'Add to Cart' : 'Sold Out' %>
            </button>

            <div style="margin-top: 30px; border-top: 1px solid #eee; padding-top: 20px;">
                <a href="/products" class="back-link" style="text-decoration: none; color: #666; font-weight: 500;">
                    ← Back to All Products
                </a>
            </div>
        </div>
    </main>

    <footer class="footer-section" style="margin-top: 100px; padding: 40px 0; background: #f4f4f4; text-align: center;">
        <div class="container">
            <p>© 2026 Ali's Tech Store | University of Karachi Project</p>
        </div>
    </footer>
</body>
</html>