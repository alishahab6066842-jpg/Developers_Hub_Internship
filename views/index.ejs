<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ecommerce | Home</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="main-header">
        <div class="container header-top">
            <div class="logo-area">
                <img src="/assets/logo-colored.png" alt="Brand" class="logo-img" />
            </div>

            
            <div class="container">
                <form action="/search" method="GET" class="search-bar">
                    <input type="text" name="q" placeholder="Search..." required>
                    <button type="submit">Search</button>
                </form>
            </div>

            <div class="user-actions">
                <span>Profile</span>
                <span>My cart</span>
            </div>
        </div>

        <div class="header-bottom">
            <div class="container nav-flex">
                <nav>
                    <a href="/">Home</a>
                    <a href="/products">All Products</a>
                    
                    <% if (typeof user !== 'undefined' && user && user.role === 'seller') { %>
                        <a href="/dashboard" style="color: #ffcc00; font-weight: bold;">Seller Dashboard</a>
                        <a href="/add">Add Product</a>
                    <% } %>

                    <% if (typeof user === 'undefined' || !user) { %>
                        <a href="/login">Login</a>
                    <% } else { %>
                        <a href="/logout">Logout</a>
                    <% } %>
                </nav>
            </div>
        </div>

    </header>

    <section class="hero-section">
        <div class="container">
            <div class="hero-content">
                <h1>Best Deals on Tech</h1>
                <p>Check out our latest arrivals for the summer season.</p>
                <a href="/products" class="btn-primary">Shop Now</a>
            </div>
        </div>
    </section>

    <section class="featured-products container">
        <h2>Featured Products</h2>
        <div class="product-grid">
            <% if (products && products.length > 0) { %>
                <% products.forEach(product => { %>
                    <div class="product-card">
                        <img src="<%= product.image %>" alt="<%= product.name %>" />
                        <div class="product-info">
                            <h3><%= product.name %></h3>
                            <p class="price">$<%= product.price %></p>
                            <a href="/product/<%= product._id %>" class="btn-secondary">View Details</a>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p>No featured products found.</p>
            <% } %>
        </div>
    </section>

    <footer class="footer-section">
        </footer>
</body>
</html>