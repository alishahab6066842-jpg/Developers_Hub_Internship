<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Seller Dashboard | Ali's Shop</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="main-header">
        <div class="container">
            <h1>Welcome, <%= sellerName %></h1>
            <nav>
                <a href="/products">View All Shop</a> | 
                <a href="/add">Add New Product</a> |
                <a href="/logout">Logout</a>
            </nav>
        </div>
    </header>

    <main class="container">
        <h2>Your Managed Inventory</h2>
        <table border="1" width="100%" style="border-collapse: collapse; margin-top: 20px;">
            <thead>
                <tr style="background-color: #f4f4f4;">
                    <th>Image</th>
                    <th>Product Name</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% products.forEach(p => { %>
                <tr>
                    <td><img src="<%= p.image %>" width="50"></td>
                    <td><%= p.name %></td>
                    <td>$<%= p.price %></td>
                    <td><%= p.stock %></td>
                    <td>
                        <a href="/products/edit/<%= p._id %>">Edit</a> | 
                        <a href="/products/delete/<%= p._id %>" style="color: red;">Delete</a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </main>
</body>
</html>